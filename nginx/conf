server {
    listen 80;
    # any domain name
    server_name _;

    # Only here to let Let's Encrypt verify ownership automatically
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Fallback to keep your normal HTTP traffic routing to the app on port 80 if needed
    location / {
        proxy_pass http://app:8000;
    }
}

server {
    listen 12345 ssl;
    server_name _;

    # Standard paths (Certbot creates a "dummy" or named folder based on your first setup)
    # You will just point this to the folder where the certs land.
    ssl_certificate /etc/letsencrypt/live/olx-certs/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/olx-certs/privkey.pem;

    # Dynamic auto-upgrade: If plain HTTP hits port 12345, automatically
    # bounce it to HTTPS using whatever domain/IP the user typed in.
    error_page 497 https://$host:$server_port$request_uri;

    location / {
        proxy_pass http://app:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
